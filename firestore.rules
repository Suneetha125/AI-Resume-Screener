rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['recruiter', 'admin'];
    }

    function isValidResume(data) {
      return data.keys().hasAll(['id', 'userId', 'fileName', 'rawText', 'createdAt']) &&
             data.userId == request.auth.uid;
    }

    function isValidJob(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'description', 'createdAt']) &&
             data.userId == request.auth.uid;
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['id', 'userId', 'resumeId', 'jobId', 'score', 'createdAt']) &&
             data.userId == request.auth.uid;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    // Resumes
    match /resumes/{resumeId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidResume(request.resource.data);
      allow update: if isDocOwner() && isValidResume(request.resource.data);
      allow delete: if isDocOwner();
    }

    // Jobs
    match /jobs/{jobId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidJob(request.resource.data);
      allow update: if isDocOwner() && isValidJob(request.resource.data);
      allow delete: if isDocOwner();
    }

    // Matches
    match /matches/{matchId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidMatch(request.resource.data);
      allow update: if isDocOwner() && isValidMatch(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
